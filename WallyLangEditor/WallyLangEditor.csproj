<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <WarningsAsErrors>Nullable</WarningsAsErrors>
    <InvariantGlobalization>true</InvariantGlobalization>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishSelfContained>true</PublishSelfContained>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>

    <DebugSymbols>false</DebugSymbols>
    <DebugType>None</DebugType>

    <Optimize>true</Optimize>
    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>full</TrimMode>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include=".\res\imgui\default_imgui.ini" />
    <EmbeddedResource Include=".\res\fonts\1_ChineseSimplified_DFPYuanW7-A Regular.ttf" />
    <EmbeddedResource Include=".\res\fonts\1_ChineseTraditional_DFPYuanMXBold-B5 Regular.ttf" />
    <EmbeddedResource Include=".\res\fonts\1_Japanese_DFGGothic-EB Regular.ttf" />
    <EmbeddedResource Include=".\res\fonts\1_Korean_BMGKorean Regular.ttf" />
    <EmbeddedResource Include=".\res\fonts\1_LatinSlimMedium_BMG Author Medium.ttf" />
    <EmbeddedResource Include=".\res\fonts\2_Russian_BMGRussianSlim Regular.ttf" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BrawlhallaLangReader\BrawlhallaLangReader.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Hexa.NET.ImGui" Version="2.2.9" />
    <PackageReference Include="NativeFileDialogSharp" Version="0.5.0" />
    <PackageReference Include="Raylib-cs" Version="7.0.2" />
  </ItemGroup>

</Project>
